{
  "name": "@dreamworld/vault",
  "description": "A secure data storage library with encrypted storage capabilities for web applications",
  "type": "module",
  "version": "0.0.0-development",
  "main": "vault.js",
  "scripts": {
    "start": "web-dev-server --node-resolve --watch --open /demo/",
    "dev": "web-dev-server --node-resolve --watch",
    "serve": "web-dev-server --node-resolve",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DreamworldSolutions/vault.git"
  },
  "keywords": [
    "encryption",
    "storage",
    "secure",
    "vault",
    "browser",
    "localstorage",
    "sessionstorage",
    "aes"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Dhruval Kodinariya",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DreamworldSolutions/vault/issues"
  },
  "homepage": "https://github.com/DreamworldSolutions/vault#readme",
  "devDependencies": {
    "semantic-release": "17.0.8",
    "@web/dev-server": "^0.4.0"
  },
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      {
          "name": "feature/*",
          "prerelease": "${name.replace(/^feature\\//g, \"\")}",
          "channel": "${name.replace(/^feature\\//g, \"\")}"
      }
    ]
  },
  "dependencies": {
    "@dreamworld/event-emitter": "^1.1.0",
    "@dreamworld/session-storage": "^1.0.0-init.2",
    "lodash-es": "^4.17.21"
  }
}
